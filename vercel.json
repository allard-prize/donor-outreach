{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm db:migrate:deploy && pnpm build",
  "crons": [
    {
      "path": "/api/cron/rss",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/email-capture",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/linkedin-scrape",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/donor-outreach",
      "schedule": "0 2 * * 1"
    }
  ]
}
