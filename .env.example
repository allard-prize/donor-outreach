# Donor Outreach — environment variables
# Copy to .env (git-ignored) for local dev, or set in Vercel project env for deploy.

# --- Database ---
# Neon Postgres connection string. Use the pooled (pgbouncer) URL for runtime
# and a direct URL for migrations (Prisma migrate needs a direct connection).
DATABASE_URL=

# --- Auth.js v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public URL the app is reachable at. Auth.js v5 auto-detects this on Vercel
# via VERCEL_URL, but set explicitly for local dev (default: http://localhost:3000)
# and for non-Vercel deploys.
AUTH_URL=http://localhost:3000

# Redirect proxy for Vercel preview deployments (Auth.js v5).
# Preview deploys get a unique URL per PR, and Google OAuth only allows EXACT,
# pre-registered redirect URIs (no wildcards) — so preview sign-in fails with
# redirect_uri_mismatch unless OAuth is routed through one stable URL. Setting
# this to the production URL + /api/auth makes every preview login go through the
# production callback (the only URI registered in Google) and hand back to the
# preview. Set the SAME value in BOTH the Preview and Production Vercel scopes
# (if unset in Production, the proxy does not engage). Leave UNSET for local dev.
# Example: https://outreach.allardprize.org/api/auth
AUTH_REDIRECT_PROXY_URL=

# Google OAuth client (allard.prize.alerts@gmail.com Google Cloud project)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated allowlist of emails that may sign in. Lowercase.
# Brian signs in as himself (developer identity); the operator (Preet today,
# successor in future) signs in as allard.prize.alerts@gmail.com so operator
# handoff is a password change, not an allowlist edit + redeploy.
ADMIN_ALLOWED_EMAILS=brian.g.flett@gmail.com,allard.prize.alerts@gmail.com

# --- OpenRouter (Phase 2C+) ---
OPENROUTER_API_KEY=

# --- Apify (Phase 2B+) ---
APIFY_API_TOKEN=

# --- Google API access for the agent (allard.prize.alerts@gmail.com) ---
# Server-side OAuth client + refresh token used by the cron handlers and scripts
# to act AS the agent account. Distinct from AUTH_GOOGLE_* above, which is only
# the interactive /admin sign-in. One refresh token carries ALL of these scopes:
#   gmail.modify           — Phase 2B email-capture (read + INBOX-label strip; supersets gmail.readonly)
#   gmail.send             — Phase 2C briefing send
#   drive.readonly         — Phase 2C dossier Doc read + Phase 2F Drive Context-folder search
#   spreadsheets.readonly  — Phase 2F Sheets→Postgres migration read
# When scopes change, regenerate via the OAuth Playground using THIS client's
# id/secret (not AUTH_GOOGLE_*) — a refresh token is bound to its issuing client.
GMAIL_OAUTH_REFRESH_TOKEN=
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=

# --- Microsoft Graph / SharePoint dossiers (Phase 2G+) ---
# Reads per-prospect dossiers from the Allard Prize Foundation SharePoint site.
# The "ONEDRIVE_" prefix is historical — the target is SharePoint, not OneDrive.
ONEDRIVE_OAUTH_REFRESH_TOKEN=
ONEDRIVE_OAUTH_CLIENT_ID=
ONEDRIVE_OAUTH_CLIENT_SECRET=
ONEDRIVE_OAUTH_TENANT_ID=

# --- Vercel Cron ---
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Briefing recipients (Phase 2C+) ---
# Comma-separated email list for weekly briefing send.
BRIEFING_RECIPIENTS=
